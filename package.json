{
  "name": "puente",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md}\""
  },
  "devDependencies": {
    "turbo": "^2.9.18",
    "typescript": "^6.0.3",
    "prettier": "^3.8.4",
    "eslint": "^10.5.0",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1"
  },
  "overrides": {
    "react": "19.2.7"
  },
  "packageManager": "npm@11.17.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
