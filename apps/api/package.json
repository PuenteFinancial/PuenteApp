    "@fastify/helmet": "^13.0.2",
    "@fastify/rate-limit": "^11.0.0",
    "@puente/shared": "*",
    "@supabase/supabase-js": "^2.108.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^6.0.0",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "supertest": "^7.2.2",
    "@types/supertest": "^7.2.0",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
