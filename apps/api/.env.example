# Server
PORT=3001
# "::" (dual-stack), not "0.0.0.0" — Node's fetch resolves localhost to ::1
# first, so an IPv4-only bind breaks the Next.js → API proxy (see local-dev.md)
HOST=::
NODE_ENV=development
LOG_LEVEL=info
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8081
# Proxy hops in front of the API. Local dev has no proxy: 0. Railway
# staging/prod: 1 (the edge proxy) — verify on staging by comparing the
# audit log's `ip` field with your real IP. Never emulate trustProxy: true —
# leftmost X-Forwarded-For is client-controlled.
TRUST_PROXY_HOPS=0

# Sentry (optional)
SENTRY_DSN=

# Supabase — find in Supabase dashboard → Connect → App Frameworks
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SECRET_KEY=sb_secret_...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# JWKS URL format: https://<project-ref>.supabase.co/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# Bridge — server-side only, never NEXT_PUBLIC_. Sandbox: https://dashboard.bridge.xyz
BRIDGE_API_KEY=
BRIDGE_API_BASE=https://api.bridge.xyz
# PEM public key issued by Bridge when the webhook is registered post-deploy —
# leave blank until then. Multiline PEM or single-line with \n both work.
BRIDGE_WEBHOOK_PUBLIC_KEY=

# Quote pricing (all optional — sane defaults in config/env.ts).
# Fee = flat + bps of send; buffer is subtracted from Bridge buy_rate;
# expiry is the firm-offer window in seconds.
QUOTE_FEE_FLAT_MINOR=0
QUOTE_FEE_BPS=100
QUOTE_FX_BUFFER_BPS=50
QUOTE_EXPIRY_SECONDS=900

# Funding (slice 4). FUNDING_PROCESSOR=mock until Stripe lands (slice 4b).
# MOCK_FUNDING_WEBHOOK_SECRET must be set in dev/staging and NEVER in
# production — its absence 503s the funding webhook + confirm (the prod lock).
# Generate: openssl rand -hex 24
FUNDING_PROCESSOR=mock
MOCK_FUNDING_WEBHOOK_SECRET=
WAIT_FOR_CLEARING=false
CANCEL_WINDOW_MINUTES=30

# AES-256-GCM key for encrypting sensitive payout-destination fields (CLABE)
# at rest. 32 bytes base64 — generate with: openssl rand -base64 32
# Boot fails without it (and fails loudly on a malformed key).
DETAILS_ENCRYPTION_KEY=

# Twilio — required once OTP auth is active (leave blank until then)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
