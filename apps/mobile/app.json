{
  "expo": {
    "name": "Puente",
    "slug": "puente",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "puente",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.puentefinancial.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.puentefinancial.app"
    },
    "plugins": [
      "expo-router",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native",
          "organization": "puente-financial"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
