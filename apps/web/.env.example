# Supabase — find these in your Supabase project:
# Project Settings → API → Project URL
SUPABASE_URL=

# Project Settings → API → service_role key (keep this secret — server only)
SUPABASE_SERVICE_ROLE_KEY=

# PostHog — find these in your PostHog project:
# Project Settings → Project → Project API key
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN=

# PostHog ingestion host (us.i.posthog.com for US region)
NEXT_PUBLIC_POSTHOG_HOST=
